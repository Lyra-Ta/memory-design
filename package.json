{
  "name": "memory-design",
  "version": "1.0.0",
  "description": "SillyTavern long-term world archive memory plugin",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build:plugin": "esbuild src/plugin/index.ts --bundle --format=iife --outfile=dist/index.js --platform=browser --target=es2020 --charset=utf8"
  },
  "keywords": [],
  "author": "Lyra-Ta",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "type": "module"
}
